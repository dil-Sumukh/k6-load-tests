{
  "testName": "BoardDocs API Load Test",
  "description": "Load and performance testing for File Permission Agent optimization validation",
  "version": "1.0.0",
  
  "target": {
    "baseUrl": "https://dev.boarddocs.com",
    "state": "ind",
    "organization": "globallogic",
    "boardNsf": "/ind/globallogic/Board.nsf"
  },
  
  "scenarios": {
    "constant_load": {
      "description": "Steady state testing with constant virtual users",
      "enabled": true,
      "vus": 10,
      "duration": "2m"
    },
    "ramp_up_down": {
      "description": "Simulates realistic traffic patterns with ramp-up and ramp-down",
      "enabled": true,
      "maxVUs": 50,
      "duration": "4m"
    },
    "stress_test": {
      "description": "Push system beyond normal limits to identify breaking points",
      "enabled": true,
      "maxVUs": 100,
      "duration": "2m30s"
    }
  },
  
  "thresholds": {
    "http_req_duration_p95": "3000ms",
    "http_req_duration_p99": "5000ms",
    "error_rate": "10%",
    "http_req_failed": "10%"
  },
  
  "apiPriorities": {
    "critical": ["javascript", "css"],
    "high": [
      "printLogo", "getPacket", "siteLogo", "welcomeImage",
      "meetingsListSEO", "public", "goto", "cssFile",
      "apiScripts", "favicon", "private", "globalJs",
      "fileDownload", "globalPng", "plusJs", "vpublic"
    ],
    "medium": [
      "globalFavicon", "getMinutes", "globalCss",
      "bdLoginCss", "rootPath", "committees", "siteLogin"
    ]
  },
  
  "execution": {
    "thinkTime": {
      "min": 0.5,
      "max": 3,
      "longPauseChance": 0.1,
      "longPauseExtra": [2, 5]
    },
    "apiCountDistribution": {
      "1_api": 20,
      "2_apis": 25,
      "3_apis": 25,
      "4_apis": 15,
      "5_apis": 10,
      "6_plus_apis": 5
    },
    "timeout": "30s"
  },
  
  "output": {
    "summaryJson": "summary.json",
    "summaryHtml": "summary.html",
    "consoleOutput": true
  }
}
